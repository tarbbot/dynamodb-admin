<!DOCTYPE html>
<html lang='en'>

<head>
  <%- include('partials/head') %>
  <%- include('partials/bootstrap-deps') %>
  <%- include('partials/head-tail') %>

  <style>
    /* Tables Grid Specific Styles */
    .tables-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: var(--space-6);
      margin-bottom: var(--space-6);
    }

    .table-card {
      position: relative;
      background: var(--color-bg-elevated);
      border: 1px solid var(--color-border-base);
      border-radius: var(--radius-xl);
      padding: var(--space-6);
      transition: all var(--duration-base) var(--ease-smooth);
      cursor: pointer;
      overflow: hidden;
    }

    .table-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 4px;
      background: var(--gradient-primary);
      opacity: 0;
      transition: opacity var(--duration-base) var(--ease-smooth);
    }

    .table-card:hover {
      transform: translateY(-4px);
      border-color: var(--color-primary);
      box-shadow: var(--shadow-lg), var(--shadow-glow-md);
    }

    .table-card:hover::before {
      opacity: 1;
    }

    .table-card-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: var(--space-4);
    }

    .table-card-title {
      font-size: var(--font-size-lg);
      font-weight: var(--font-weight-semibold);
      color: var(--color-text-primary);
      margin: 0;
      flex: 1;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .table-card-count {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 48px;
      padding: var(--space-2) var(--space-3);
      background: rgba(var(--color-bg-overlay-rgb), 0.8);
      border: 1px solid var(--color-border-base);
      border-radius: var(--radius-full);
      font-size: var(--font-size-sm);
      font-weight: var(--font-weight-semibold);
      color: var(--color-primary);
      margin-left: var(--space-3);
    }

    .table-card-actions {
      display: flex;
      gap: var(--space-2);
      margin-top: var(--space-4);
      padding-top: var(--space-4);
      border-top: 1px solid var(--color-border-base);
    }

    .table-card-action {
      flex: 1;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: var(--space-2);
      padding: var(--space-2) var(--space-3);
      font-size: var(--font-size-sm);
      font-weight: var(--font-weight-medium);
      border-radius: var(--radius-md);
      transition: all var(--duration-fast) var(--ease-smooth);
      cursor: pointer;
      text-decoration: none;
    }

    .table-card-action-view {
      background: var(--color-primary);
      color: white !important;
    }

    .table-card-action-view:hover {
      background: var(--color-primary-light);
      color: white !important;
      transform: translateY(-1px);
      box-shadow: 0 4px 12px rgba(139, 92, 246, 0.4);
    }

    .table-card-action-purge {
      background: transparent;
      color: var(--color-warning);
      border: 1px solid var(--color-warning);
    }

    .table-card-action-purge:hover {
      background: var(--color-warning);
      color: white;
    }

    .table-card-action-delete {
      background: transparent;
      color: var(--color-danger);
      border: 1px solid var(--color-danger);
    }

    .table-card-action-delete:hover {
      background: var(--color-danger);
      color: white;
    }

    .search-container {
      position: relative;
      margin-bottom: var(--space-6);
    }

    .search-icon {
      position: absolute;
      left: var(--space-4);
      top: 50%;
      transform: translateY(-50%);
      color: var(--color-text-tertiary);
      pointer-events: none;
    }

    .search-input {
      width: 100%;
      padding: var(--space-4) var(--space-4) var(--space-4) var(--space-12);
      font-size: var(--font-size-base);
      background: var(--color-bg-elevated);
      border: 2px solid var(--color-border-base);
      border-radius: var(--radius-xl);
      color: var(--color-text-primary);
      transition: all var(--duration-fast) var(--ease-smooth);
    }

    .search-input:focus {
      outline: none;
      border-color: var(--color-primary);
      box-shadow: 0 0 0 3px rgba(139, 92, 246, 0.1);
      background: var(--color-bg-base);
    }

    .search-input::placeholder {
      color: var(--color-text-tertiary);
    }

    .actions-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: var(--space-4);
      margin-bottom: var(--space-8);
      flex-wrap: wrap;
    }

    .actions-group {
      display: flex;
      gap: var(--space-3);
    }

    .empty-state {
      text-align: center;
      padding: var(--space-16) var(--space-8);
    }

    .empty-state-icon {
      font-size: 4rem;
      margin-bottom: var(--space-4);
      opacity: 0.5;
    }

    /* View Toggle */
    .view-toggle {
      background: transparent !important;
      border: none !important;
      color: var(--color-text-tertiary) !important;
      opacity: 0.6;
      transition: all var(--duration-fast) var(--ease-smooth) !important;
    }

    .view-toggle:hover {
      opacity: 1;
      transform: none !important;
    }

    .view-toggle.active {
      background: var(--color-primary) !important;
      color: white !important;
      opacity: 1;
    }

    /* List View */
    .tables-list {
      display: flex;
      flex-direction: column;
      gap: var(--space-3);
    }

    .tables-list .table-card {
      display: flex;
      flex-direction: row;
      align-items: center;
      gap: var(--space-4);
      padding: var(--space-4);
    }

    .tables-list .table-card-header {
      flex: 1;
      margin-bottom: 0;
    }

    .tables-list .table-card-actions {
      margin: 0;
      padding: 0;
      border: none;
      flex-direction: row;
      width: auto;
    }

    .tables-list .table-card-action {
      padding: var(--space-2) var(--space-4);
    }

    @media (max-width: 768px) {
      .tables-grid {
        grid-template-columns: 1fr;
      }

      .actions-bar {
        flex-direction: column;
        align-items: stretch;
      }

      .actions-group {
        width: 100%;
      }

      .actions-group .btn {
        flex: 1;
      }
    }
  </style>
</head>

<body class='container'>
  <header>
    <%
      const breadcrumb = [
        {
          active: true,
          href: '/',
          text: 'Tables',
          badge: data.length
        },
      ]
    %>
    <%- include('partials/breadcrumb', { breadcrumb }) %>
    <%- include('partials/error-container') %>
  </header>

  <main class="page-enter">
    <!-- Search -->
    <div class="search-container">
      <svg class="search-icon" width="20" height="20" viewBox="0 0 20 20" fill="none">
        <circle cx="9" cy="9" r="6" stroke="currentColor" stroke-width="2"/>
        <path d="M14 14l4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
      <input
        type="search"
        class="search-input"
        id="filter-input"
        placeholder="Search tables by name..."
        autocomplete="off"
      >
    </div>

    <!-- Actions Bar -->
    <div class="actions-bar">
      <div style="display: flex; gap: var(--space-3); align-items: center;">
        <a href='/create-table' class="btn btn-primary btn-lg">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
          Create Table
        </a>

        <!-- View Toggle -->
        <div class="btn-group" role="group" style="display: flex; gap: 4px; background: var(--color-bg-elevated); border-radius: var(--radius-lg); padding: 4px;">
          <button class="btn btn-sm view-toggle active" data-view="grid" onclick="toggleView('grid')" style="padding: var(--space-2) var(--space-3);">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
              <rect x="1" y="1" width="6" height="6" rx="1"/>
              <rect x="9" y="1" width="6" height="6" rx="1"/>
              <rect x="1" y="9" width="6" height="6" rx="1"/>
              <rect x="9" y="9" width="6" height="6" rx="1"/>
            </svg>
          </button>
          <button class="btn btn-sm view-toggle" data-view="list" onclick="toggleView('list')" style="padding: var(--space-2) var(--space-3);">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
              <rect x="1" y="2" width="14" height="2" rx="1"/>
              <rect x="1" y="7" width="14" height="2" rx="1"/>
              <rect x="1" y="12" width="14" height="2" rx="1"/>
            </svg>
          </button>
        </div>
      </div>

      <div class="actions-group">
        <button class="btn btn-warning" onclick="purgeAllTables(); return false;">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M2 4h12M5 4V2h6v2M7 7v4M9 7v4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
          Purge All
        </button>
        <button class="btn btn-danger" onclick="deleteAllTables(); return false;">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M4 4l8 8M12 4l-8 8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
          Delete All
        </button>
      </div>
    </div>

    <!-- Tables Grid -->
    <div class="tables-grid" id="table-list">
      <% if (data.length === 0) { %>
        <div class="empty-state" style="grid-column: 1 / -1;">
          <div class="empty-state-icon">📦</div>
          <h3 class="empty-state-title">No Tables Found</h3>
          <p class="empty-state-description">Get started by creating your first DynamoDB table</p>
          <a href='/create-table' class="btn btn-primary" style="margin-top: var(--space-4);">
            Create Your First Table
          </a>
        </div>
      <% } else { %>
        <% for(var i = 0; i < data.length; i++) { %>
          <div class="table-card stagger-item" data-table-name="<%= data[i].TableName %>" style="animation-delay: <%= i * 30 %>ms;">
            <div class="table-card-header">
              <h3 class="table-card-title" title="<%= data[i].TableName %>">
                <%= data[i].TableName %>
              </h3>
              <div class="table-card-count" data-count="<%= data[i].ItemCount %>">
                <%= data[i].ItemCount.toLocaleString() %>
              </div>
            </div>

            <div class="table-card-actions">
              <a
                href='/tables/<%= encodeURIComponent(data[i].TableName) %>'
                class="table-card-action table-card-action-view"
              >
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <circle cx="8" cy="8" r="3" stroke="currentColor" stroke-width="2"/>
                  <path d="M1 8s3-5 7-5 7 5 7 5-3 5-7 5-7-5-7-5z" stroke="currentColor" stroke-width="2"/>
                </svg>
                View
              </a>

              <button
                class="table-card-action table-card-action-purge"
                onclick="purgeTable('<%= data[i].TableName %>'); return false;"
              >
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <path d="M2 4h12M5 4V2h6v2" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                  <path d="M3 4v9a1 1 0 001 1h8a1 1 0 001-1V4" stroke="currentColor" stroke-width="2"/>
                </svg>
                Purge
              </button>

              <button
                class="table-card-action table-card-action-delete"
                onclick="deleteTable('<%= data[i].TableName %>'); return false;"
              >
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <path d="M4 4l8 8M12 4l-8 8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
                Delete
              </button>
            </div>
          </div>
        <% } %>
      <% } %>
    </div>
  </main>

  <script>
    // View Toggle
    function toggleView(view) {
      const grid = document.getElementById('table-list');
      const buttons = document.querySelectorAll('.view-toggle');

      buttons.forEach(btn => {
        if (btn.dataset.view === view) {
          btn.classList.add('active');
        } else {
          btn.classList.remove('active');
        }
      });

      if (view === 'list') {
        grid.classList.remove('tables-grid');
        grid.classList.add('tables-list');
      } else {
        grid.classList.remove('tables-list');
        grid.classList.add('tables-grid');
      }

      // Save preference
      localStorage.setItem('tablesView', view);
    }

    // Load saved view preference
    window.addEventListener('DOMContentLoaded', () => {
      const savedView = localStorage.getItem('tablesView') || 'grid';
      if (savedView === 'list') {
        toggleView('list');
      }
    });

    // Filter functionality
    $(document).ready(() => {
      $('#filter-input')
        .on('input', event => {
          const query = event.target.value.trim().toLowerCase()
          const words = query.split(' ').map(word => word.trim()).filter(word => word)
          const cards = $('.table-card');

          if (words.length === 0) {
            cards.show();
          } else {
            cards.each((index, element) => {
              const tableName = element.dataset.tableName.toLowerCase()
              const matches = words.every(word => tableName.includes(word))
              $(element).toggle(matches);
            });
          }

          window.history.replaceState({}, undefined, getUrlWithState({ filter: query }))
        })
        .trigger('input')

      // Animate counters on load
      $('.table-card-count').each((index, element) => {
        const count = parseInt(element.dataset.count) || 0;
        if (window.animateCounter) {
          setTimeout(() => {
            window.animateCounter(element, count, 800);
          }, index * 50);
        }
      });
    })

    function getUrlWithState({ filter }) {
      const url = new URL(location.href);
      if (filter) {
        url.searchParams.set('filter', filter)
      } else {
        url.searchParams.delete('filter')
      }
      return url.toString()
    }

    // Modern delete with modal
    async function deleteTable(TableName) {
      const confirmed = await window.modal.confirm({
        title: 'Delete Table?',
        message: `Are you sure you want to permanently delete table "${TableName}"? This action cannot be undone.`,
        type: 'danger',
        confirmText: 'Delete Table',
        cancelText: 'Cancel'
      });

      if (!confirmed) return;

      window.loading.show(`Deleting table "${TableName}"...`);

      try {
        const response = await fetch(`/tables/${encodeURIComponent(TableName)}`, {
          method: 'delete'
        });

        if (!response.ok) {
          const responseText = await response.text();
          throw new Error(JSON.parse(responseText).message);
        }

        window.loading.hide();
        window.toast.success(`Table "${TableName}" deleted successfully`);

        setTimeout(() => location.reload(), 1000);
      } catch (error) {
        window.loading.hide();
        handleError(error.message);
      }
    }

    // Modern purge with modal
    async function purgeTable(TableName) {
      const confirmed = await window.modal.confirm({
        title: 'Purge Table?',
        message: `Are you sure you want to delete all records from table "${TableName}"? The table structure will remain intact.`,
        type: 'warning',
        confirmText: 'Purge Records',
        cancelText: 'Cancel'
      });

      if (!confirmed) return;

      window.loading.show(`Purging all records from "${TableName}"...`);

      try {
        const response = await fetch(`/tables/${encodeURIComponent(TableName)}/all`, {
          method: 'delete'
        });

        if (!response.ok) {
          const responseText = await response.text();
          throw new Error(JSON.parse(responseText).message);
        }

        window.loading.hide();
        window.toast.success(`Table "${TableName}" purged successfully`);

        setTimeout(() => location.reload(), 1000);
      } catch (error) {
        window.loading.hide();
        handleError(error.message);
      }
    }

    // Purge all tables
    async function purgeAllTables() {
      const confirmed = await window.modal.confirm({
        title: 'Purge All Tables?',
        message: 'Are you sure you want to delete all records from ALL tables? Table structures will remain intact.',
        type: 'warning',
        confirmText: 'Purge All Tables',
        cancelText: 'Cancel'
      });

      if (!confirmed) return;

      window.loading.show('Purging all tables...');

      try {
        const response = await fetch('/tables-purge', {
          method: 'delete'
        });

        const responseText = await response.text();

        if (!response.ok) {
          throw new Error(JSON.parse(responseText).message);
        }

        window.loading.hide();
        window.toast.success(responseText);

        setTimeout(() => location.reload(), 1500);
      } catch (error) {
        window.loading.hide();
        handleError(error.message);
      }
    }

    // Delete all tables
    async function deleteAllTables() {
      const confirmed = await window.modal.confirm({
        title: 'Delete All Tables?',
        message: 'Are you sure you want to PERMANENTLY DELETE all tables? This action cannot be undone and all data will be lost.',
        type: 'danger',
        confirmText: 'Delete All Tables',
        cancelText: 'Cancel'
      });

      if (!confirmed) return;

      window.loading.show('Deleting all tables...');

      try {
        const response = await fetch('/tables', {
          method: 'delete'
        });

        const responseText = await response.text();

        if (!response.ok) {
          throw new Error(JSON.parse(responseText).message);
        }

        window.loading.hide();
        window.toast.success(responseText);

        setTimeout(() => location.reload(), 1500);
      } catch (error) {
        window.loading.hide();
        handleError(error.message);
      }
    }
  </script>
</body>
</html>
