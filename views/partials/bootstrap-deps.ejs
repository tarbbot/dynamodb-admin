<script src='/assets/vendor/bootstrap/jquery.cookie.min.js'></script>
<script src='/assets/vendor/bootstrap/bootstrap.bundle.min.js'></script>

<!-- Modern Component System -->
<script src='/assets/js/components.js'></script>
<script src='/assets/js/background-effects.js'></script>
<script src='/assets/js/theme-manager.js'></script>

<script>
  $(function () {
    $('[data-toggle="tooltip"]').tooltip()
  });

  // Modern error handler using toast
  function handleError(errorText) {
    if (window.toast) {
      window.toast.error(errorText, 5000);
    } else {
      // Fallback to legacy
      const errorEl = $('#error-wrapper')
      if (errorEl.length) {
        $('#error-wrapper').html('<div class="alert alert-danger" role="alert">' + errorText + '</div>')[0].scrollIntoView({
          behavior: 'smooth',
        });
      } else {
        window.alert(errorText)
      }
    }
  }
</script>
