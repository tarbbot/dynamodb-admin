<nav class="breadcrumb" style="display: flex; align-items: center; gap: var(--space-3);">
  <% for (let i = 0; i < breadcrumb.length; i++) { %>
    <% const item = breadcrumb[i]; %>
    <div class="breadcrumb-item <%= item.active ? 'active' : '' %>">
      <% if (item.href && !item.active) { %>
        <a href="<%= item.href %>"><%= item.text %></a>
      <% } else { %>
        <%= item.text %>
      <% } %>
      <% if (item.badge) { %>
        <span class="badge badge-primary badge-lg" style="margin-left: var(--space-2);"><%= item.badge %></span>
      <% } %>
    </div>
    <% if (i < breadcrumb.length - 1) { %>
      <span class="breadcrumb-separator">/</span>
    <% } %>
  <% } %>

  <!-- Theme selector will be injected here by theme-manager.js -->
</nav>
